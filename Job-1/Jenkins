pipeline {
    agent any

    tools {
        maven 'Maven' // name from Manage Jenkins > Global Tool Configuration
    }

    stages {
        stage('Declarative: Checkout SCM') {
            steps {
                checkout scm
            }
        }

        stage('Declarative: Tool Install') {
            steps {
                sh 'mvn -version'
            }
        }

        stage('Git Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/your-repo.git'
            }
        }

        stage('Maven clean') {
            steps {
                sh 'mvn clean'
            }
        }

        stage('Maven build') {
            steps {
                sh 'mvn package'
            }
        }
    }
}
