pipeline {
    agent any
    tools {
        maven 'Maven'
        jdk 'Java_11'
    }
    stages {
        stage('Git Checkout') {
            steps {
                git branch: 'Jenkins', url: 'https://github.com/sharath050175/DevOps.git'
            }
        }
        stage('Maven Clean') {
            steps {
                sh 'mvn clean'
            }
        }
        stage('Maven Package') {
            steps {
                sh 'mvn package'
            }
        }
    }
}
